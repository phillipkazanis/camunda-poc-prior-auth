<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="prior-auth-dmn" name="Prior Auth Clinical Criteria" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="prior-auth-clinical-criteria" name="Clinical Criteria Assessment">
    <decisionTable id="decisionTable_1" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Code">
        <inputExpression id="inputExpression_1" typeRef="string">
          <text>procedureCode</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Coverage Type">
        <inputExpression id="inputExpression_2" typeRef="string">
          <text>coverageType</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Urgency Level">
        <inputExpression id="inputExpression_3" typeRef="string">
          <text>urgencyLevel</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Diagnosis">
        <inputExpression id="inputExpression_4" typeRef="string">
          <text>diagnosis</text>
        </inputExpression>
      </input>
      <output id="output_1" label="Decision" name="decision" typeRef="string" />
      <output id="output_2" label="Reason" name="reason" typeRef="string" />
      <output id="output_3" label="Priority" name="priority" typeRef="string" />

      <!-- URGENT cases always escalate for human review -->
      <rule id="rule_urgent">
        <inputEntry id="ie_1_1"><text></text></inputEntry>
        <inputEntry id="ie_1_2"><text></text></inputEntry>
        <inputEntry id="ie_1_3"><text>"urgent"</text></inputEntry>
        <inputEntry id="ie_1_4"><text></text></inputEntry>
        <outputEntry id="oe_1_1"><text>"escalate"</text></outputEntry>
        <outputEntry id="oe_1_2"><text>"Urgent case requires clinical review before approval"</text></outputEntry>
        <outputEntry id="oe_1_3"><text>"high"</text></outputEntry>
      </rule>

      <!-- MRI — Lumbar — approve if basic or comprehensive cover -->
      <rule id="rule_mri_lumbar_approve">
        <inputEntry id="ie_2_1"><text>"MRI-LUMBAR"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>"basic", "comprehensive", "premium"</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"routine", "semi-urgent"</text></inputEntry>
        <inputEntry id="ie_2_4"><text></text></inputEntry>
        <outputEntry id="oe_2_1"><text>"approve"</text></outputEntry>
        <outputEntry id="oe_2_2"><text>"MRI Lumbar approved — procedure covered under patient policy"</text></outputEntry>
        <outputEntry id="oe_2_3"><text>"standard"</text></outputEntry>
      </rule>

      <!-- MRI — Brain — escalate for clinical review -->
      <rule id="rule_mri_brain_escalate">
        <inputEntry id="ie_3_1"><text>"MRI-BRAIN"</text></inputEntry>
        <inputEntry id="ie_3_2"><text></text></inputEntry>
        <inputEntry id="ie_3_3"><text></text></inputEntry>
        <inputEntry id="ie_3_4"><text></text></inputEntry>
        <outputEntry id="oe_3_1"><text>"escalate"</text></outputEntry>
        <outputEntry id="oe_3_2"><text>"MRI Brain requires clinical review — neurological justification needed"</text></outputEntry>
        <outputEntry id="oe_3_3"><text>"high"</text></outputEntry>
      </rule>

      <!-- CT Scan — approve if comprehensive or premium -->
      <rule id="rule_ct_approve">
        <inputEntry id="ie_4_1"><text>"CT-SCAN"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"comprehensive", "premium"</text></inputEntry>
        <inputEntry id="ie_4_3"><text></text></inputEntry>
        <inputEntry id="ie_4_4"><text></text></inputEntry>
        <outputEntry id="oe_4_1"><text>"approve"</text></outputEntry>
        <outputEntry id="oe_4_2"><text>"CT Scan approved — covered under comprehensive or premium policy"</text></outputEntry>
        <outputEntry id="oe_4_3"><text>"standard"</text></outputEntry>
      </rule>

      <!-- CT Scan — escalate if basic cover -->
      <rule id="rule_ct_basic_escalate">
        <inputEntry id="ie_5_1"><text>"CT-SCAN"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>"basic"</text></inputEntry>
        <inputEntry id="ie_5_3"><text></text></inputEntry>
        <inputEntry id="ie_5_4"><text></text></inputEntry>
        <outputEntry id="oe_5_1"><text>"escalate"</text></outputEntry>
        <outputEntry id="oe_5_2"><text>"CT Scan requires clinical justification for basic cover policy"</text></outputEntry>
        <outputEntry id="oe_5_3"><text>"medium"</text></outputEntry>
      </rule>

      <!-- Specialist Consultation — approve -->
      <rule id="rule_specialist_approve">
        <inputEntry id="ie_6_1"><text>"SPEC-CONSULT"</text></inputEntry>
        <inputEntry id="ie_6_2"><text>"basic", "comprehensive", "premium"</text></inputEntry>
        <inputEntry id="ie_6_3"><text></text></inputEntry>
        <inputEntry id="ie_6_4"><text></text></inputEntry>
        <outputEntry id="oe_6_1"><text>"approve"</text></outputEntry>
        <outputEntry id="oe_6_2"><text>"Specialist consultation approved — covered under patient policy"</text></outputEntry>
        <outputEntry id="oe_6_3"><text>"standard"</text></outputEntry>
      </rule>

      <!-- Surgery — escalate always -->
      <rule id="rule_surgery_escalate">
        <inputEntry id="ie_7_1"><text>"SURGERY"</text></inputEntry>
        <inputEntry id="ie_7_2"><text></text></inputEntry>
        <inputEntry id="ie_7_3"><text></text></inputEntry>
        <inputEntry id="ie_7_4"><text></text></inputEntry>
        <outputEntry id="oe_7_1"><text>"escalate"</text></outputEntry>
        <outputEntry id="oe_7_2"><text>"Surgical procedures require mandatory clinical review"</text></outputEntry>
        <outputEntry id="oe_7_3"><text>"high"</text></outputEntry>
      </rule>

      <!-- No cover — reject -->
      <rule id="rule_no_cover_reject">
        <inputEntry id="ie_8_1"><text></text></inputEntry>
        <inputEntry id="ie_8_2"><text>"none", "expired"</text></inputEntry>
        <inputEntry id="ie_8_3"><text></text></inputEntry>
        <inputEntry id="ie_8_4"><text></text></inputEntry>
        <outputEntry id="oe_8_1"><text>"reject"</text></outputEntry>
        <outputEntry id="oe_8_2"><text>"Patient does not have active coverage for this procedure"</text></outputEntry>
        <outputEntry id="oe_8_3"><text>"standard"</text></outputEntry>
      </rule>

      <!-- Default — escalate -->
      <rule id="rule_default_escalate">
        <inputEntry id="ie_9_1"><text></text></inputEntry>
        <inputEntry id="ie_9_2"><text></text></inputEntry>
        <inputEntry id="ie_9_3"><text></text></inputEntry>
        <inputEntry id="ie_9_4"><text></text></inputEntry>
        <outputEntry id="oe_9_1"><text>"escalate"</text></outputEntry>
        <outputEntry id="oe_9_2"><text>"Procedure not matched to standard criteria — requires clinical review"</text></outputEntry>
        <outputEntry id="oe_9_3"><text>"medium"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>
</definitions>
