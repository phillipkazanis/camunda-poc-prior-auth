<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="8cca9cf" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="prior-auth-process" name="Prior Authorisation" isExecutable="true">

    <bpmn:startEvent id="StartEvent_1" name="Prior Auth Request Received">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="prior-auth-start-form" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_CheckEligibility" name="Check Patient Eligibility" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="={{secrets.ELIGIBILITY_API_URL}}/eligibility/{{patientId}}" target="url" />
          <zeebe:input source="=30" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="eligibilityResult" />
          <zeebe:header key="resultExpression" value="={&#10;  &quot;eligible&quot;: response.body.eligible,&#10;  &quot;coverageType&quot;: response.body.coverageType,&#10;  &quot;patientName&quot;: response.body.patientName&#10;}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:adHocSubProcess id="Activity_Agent" name="Prior Auth AI Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="us-east-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.BEDROCK_API_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.BEDROCK_API_ACCESS_SECRET}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=10000" target="provider.bedrock.model.parameters.maxTokens" />
          <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.temperature" />
          <zeebe:input source="=&#34;You are a **PriorAuthEvaluationAgent** reviewing prior authorisation requests for medical procedures. You have access to tools to help you evaluate the clinical documentation and make a recommendation. Be systematic and thorough. Always use the document analysis tool first, then summarise the case before making a recommendation.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;A prior authorisation request has been submitted. Patient: &#34; + patientName + &#34; | Procedure: &#34; + procedureRequested + &#34; | Diagnosis: &#34; + diagnosis + &#34; | Coverage: &#34; + eligibilityResult.coverageType + &#34;. Analyse the clinical documentation and provide a case summary with your recommendation.&#34;" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=false" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>

      <bpmn:callActivity id="Task_ExtractDocuments" name="extract clinical documents">
        <bpmn:documentation>Use this to extract and analyse the clinical documentation submitted with the prior auth request. Returns diagnosis details, procedure justification, clinical indicators and any missing information.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:calledElement processId="prior-auth-document-extraction" propagateAllChildVariables="true" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.documentRef, &quot;the reference to the clinical document to analyse&quot;, &quot;string&quot;)" target="documentRef" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:callActivity>

      <bpmn:serviceTask id="Task_SummariseCase" name="summarise case for review">
        <bpmn:documentation>Use this to create a structured case summary combining patient eligibility, clinical document analysis and procedure justification. Call this after extracting documents.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="bedrock" target="provider.type" />
            <zeebe:input source="us-east-1" target="provider.bedrock.region" />
            <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
            <zeebe:input source="{{secrets.BEDROCK_API_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
            <zeebe:input source="{{secrets.BEDROCK_API_ACCESS_SECRET}}" target="provider.bedrock.authentication.secretKey" />
            <zeebe:input source="us.anthropic.claude-sonnet-4-20250514-v1:0" target="provider.bedrock.model.model" />
            <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens" />
            <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.temperature" />
            <zeebe:input source="=&#34;You are a clinical case summariser. Create a concise structured summary for clinical review.&#34;" target="data.systemPrompt.prompt" />
            <zeebe:input source="=&#34;Summarise this prior auth case for clinical review. Patient: &#34; + patientName + &#34; | Procedure: &#34; + procedureRequested + &#34; | Diagnosis: &#34; + diagnosis + &#34; | Coverage: &#34; + eligibilityResult.coverageType + &#34; | Document analysis: &#34; + string(extractedClinicalData) + &#34;. Preserve: clinical justification, urgency indicators, missing information, recommendation.&#34;" target="data.userPrompt.prompt" />
            <zeebe:input source="=agent.context" target="data.context" />
            <zeebe:input source="in-process" target="data.memory.storage.type" />
            <zeebe:input source="=20" target="data.memory.contextWindowSize" />
            <zeebe:input source="=5" target="data.limits.maxModelCalls" />
            <zeebe:input source="text" target="data.response.format.type" />
            <zeebe:input source="=false" target="data.response.format.parseJson" />
            <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="5" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
            <zeebe:header key="resultVariable" value="agent" />
            <zeebe:header key="resultExpression" value="={&quot;toolCallResult&quot;: responseText, &quot;caseSummary&quot;: responseText}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>

    </bpmn:adHocSubProcess>

    <bpmn:businessRuleTask id="Task_DMN" name="Apply Clinical Criteria">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="prior-auth-clinical-criteria" resultVariable="authDecision" />
        <zeebe:ioMapping>
          <zeebe:input source="=diagnosis" target="diagnosis" />
          <zeebe:input source="=procedureCode" target="procedureCode" />
          <zeebe:input source="=eligibilityResult.coverageType" target="coverageType" />
          <zeebe:input source="=urgencyLevel" target="urgencyLevel" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:exclusiveGateway id="Gateway_Decision" name="Authorisation Decision">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoApprove</bpmn:outgoing>
      <bpmn:outgoing>Flow_Escalate</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_NotifyApproved" name="Notify GP and Patient — Approved">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_USER}}" target="authentication.username" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="{{secrets.OUTBOUND_MAIL_SERVER}}" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=465" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="SSL" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_ADDRESS}}" target="data.smtpAction.from" />
          <zeebe:input source="=gpEmail" target="data.smtpAction.to" />
          <zeebe:input source="=&quot;Prior Authorisation APPROVED — &quot; + patientName + &quot; — &quot; + procedureRequested" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=&quot;Dear Dr &quot; + gpName + &quot;,\n\nWe are pleased to inform you that the prior authorisation request for the following has been APPROVED:\n\nPatient: &quot; + patientName + &quot;\nProcedure: &quot; + procedureRequested + &quot;\nDiagnosis: &quot; + diagnosis + &quot;\n\nAuthorisation Reference: &quot; + string(instance.key) + &quot;\nDecision: Automatic approval based on clinical criteria\n\nThe patient may proceed with the approved procedure.\n\nPrior Authorisation Processing&quot;" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="notifyResult" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AutoApprove</bpmn:incoming>
      <bpmn:outgoing>Flow_EndApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="Task_ClinicalOverride" name="Clinical Override Review">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="prior-auth-clinical-override-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=caseSummary" target="caseSummary" />
          <zeebe:input source="=patientName" target="patientName" />
          <zeebe:input source="=procedureRequested" target="procedureRequested" />
          <zeebe:input source="=diagnosis" target="diagnosis" />
          <zeebe:input source="=authDecision.reason" target="escalationReason" />
          <zeebe:input source="=eligibilityResult.coverageType" target="coverageType" />
          <zeebe:input source="=urgencyLevel" target="urgencyLevel" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Escalate</bpmn:incoming>
      <bpmn:outgoing>Flow_AfterOverride</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Override" name="Override Decision">
      <bpmn:incoming>Flow_AfterOverride</bpmn:incoming>
      <bpmn:outgoing>Flow_OverrideApprove</bpmn:outgoing>
      <bpmn:outgoing>Flow_OverrideReject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_NotifyRejected" name="Notify GP and Patient — Rejected">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_USER}}" target="authentication.username" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="{{secrets.OUTBOUND_MAIL_SERVER}}" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=465" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="SSL" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_ADDRESS}}" target="data.smtpAction.from" />
          <zeebe:input source="=gpEmail" target="data.smtpAction.to" />
          <zeebe:input source="=&quot;Prior Authorisation NOT APPROVED — &quot; + patientName + &quot; — &quot; + procedureRequested" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=&quot;Dear Dr &quot; + gpName + &quot;,\n\nUnfortunately the prior authorisation request for the following has NOT been approved at this time:\n\nPatient: &quot; + patientName + &quot;\nProcedure: &quot; + procedureRequested + &quot;\nDiagnosis: &quot; + diagnosis + &quot;\n\nReason: &quot; + authDecision.reason + &quot;\n\nIf you believe this decision is incorrect, please submit additional clinical documentation for review.\n\nPrior Authorisation Processing&quot;" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="notifyResult" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:incoming>Flow_OverrideReject</bpmn:incoming>
      <bpmn:outgoing>Flow_EndRejected</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_NotifyOverrideApproved" name="Notify GP and Patient — Clinician Approved">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_USER}}" target="authentication.username" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="{{secrets.OUTBOUND_MAIL_SERVER}}" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="=465" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="SSL" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.INBOUND_MAIL_ADDRESS}}" target="data.smtpAction.from" />
          <zeebe:input source="=gpEmail" target="data.smtpAction.to" />
          <zeebe:input source="=&quot;Prior Authorisation APPROVED (Clinical Review) — &quot; + patientName + &quot; — &quot; + procedureRequested" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="=&quot;Dear Dr &quot; + gpName + &quot;,\n\nFollowing clinical review, the prior authorisation request has been APPROVED:\n\nPatient: &quot; + patientName + &quot;\nProcedure: &quot; + procedureRequested + &quot;\nDiagnosis: &quot; + diagnosis + &quot;\n\nAuthorisation Reference: &quot; + string(instance.key) + &quot;\nDecision: Approved following clinical override review\nReviewer notes: &quot; + reviewerNotes + &quot;\n\nThe patient may proceed with the approved procedure.\n\nPrior Authorisation Processing&quot;" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="notifyResult" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_OverrideApprove</bpmn:incoming>
      <bpmn:outgoing>Flow_EndOverrideApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_Approved" name="Authorisation Approved">
      <bpmn:incoming>Flow_EndApproved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="Authorisation Rejected">
      <bpmn:incoming>Flow_EndRejected</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_OverrideApproved" name="Approved — Clinical Override">
      <bpmn:incoming>Flow_EndOverrideApproved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CheckEligibility" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CheckEligibility" targetRef="Activity_Agent" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Activity_Agent" targetRef="Task_DMN" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_DMN" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_AutoApprove" name="Auto Approve" sourceRef="Gateway_Decision" targetRef="Task_NotifyApproved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=authDecision.decision = "approve"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Escalate" name="Escalate to Clinical Review" sourceRef="Gateway_Decision" targetRef="Task_ClinicalOverride">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=authDecision.decision = "escalate"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Reject" name="Reject" sourceRef="Gateway_Decision" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=authDecision.decision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_AfterOverride" sourceRef="Task_ClinicalOverride" targetRef="Gateway_Override" />
    <bpmn:sequenceFlow id="Flow_OverrideApprove" name="Approve" sourceRef="Gateway_Override" targetRef="Task_NotifyOverrideApproved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=overrideDecision = "approve"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_OverrideReject" name="Reject" sourceRef="Gateway_Override" targetRef="Task_NotifyRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=overrideDecision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EndApproved" sourceRef="Task_NotifyApproved" targetRef="EndEvent_Approved" />
    <bpmn:sequenceFlow id="Flow_EndRejected" sourceRef="Task_NotifyRejected" targetRef="EndEvent_Rejected" />
    <bpmn:sequenceFlow id="Flow_EndOverrideApproved" sourceRef="Task_NotifyOverrideApproved" targetRef="EndEvent_OverrideApproved" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="prior-auth-process">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1"><dc:Bounds x="152" y="242" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="126" y="285" width="89" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckEligibility_di" bpmnElement="Task_CheckEligibility"><dc:Bounds x="240" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Agent_di" bpmnElement="Activity_Agent" isExpanded="true"><dc:Bounds x="390" y="120" width="400" height="280" /><bpmndi:BPMNLabel /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExtractDocuments_di" bpmnElement="Task_ExtractDocuments"><dc:Bounds x="430" y="200" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SummariseCase_di" bpmnElement="Task_SummariseCase"><dc:Bounds x="590" y="200" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DMN_di" bpmnElement="Task_DMN"><dc:Bounds x="850" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true"><dc:Bounds x="1005" y="235" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyApproved_di" bpmnElement="Task_NotifyApproved"><dc:Bounds x="1110" y="140" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ClinicalOverride_di" bpmnElement="Task_ClinicalOverride"><dc:Bounds x="1110" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyRejected_di" bpmnElement="Task_NotifyRejected"><dc:Bounds x="1110" y="340" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Override_di" bpmnElement="Gateway_Override" isMarkerVisible="true"><dc:Bounds x="1265" y="235" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyOverrideApproved_di" bpmnElement="Task_NotifyOverrideApproved"><dc:Bounds x="1370" y="220" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved"><dc:Bounds x="1262" y="162" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1238" y="205" width="84" height="27" /></bpmndi:BPMNLabel></bpmndi:BPMNShape>
