{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.9.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "8cca9cf"
  },
  "schemaVersion": 19,
  "id": "prior-auth-clinical-override-form",
  "components": [
    {
      "text": "### Clinical Override Review\nThis request has been escalated for clinical review. Please review the case summary below and make a decision.",
      "type": "text",
      "layout": {
        "row": "Row_header",
        "columns": null
      },
      "id": "Field_header"
    },
    {
      "label": "Case Summary",
      "components": [
        {
          "label": "Patient Name",
          "type": "textfield",
          "layout": {
            "row": "Row_1",
            "columns": null
          },
          "id": "Field_patientName",
          "key": "patientName",
          "readonly": true
        },
        {
          "label": "Procedure Requested",
          "type": "textfield",
          "layout": {
            "row": "Row_1",
            "columns": null
          },
          "id": "Field_procedure",
          "key": "procedureRequested",
          "readonly": true
        },
        {
          "label": "Diagnosis",
          "type": "textfield",
          "layout": {
            "row": "Row_2",
            "columns": null
          },
          "id": "Field_diagnosis",
          "key": "diagnosis",
          "readonly": true
        },
        {
          "label": "Coverage Type",
          "type": "textfield",
          "layout": {
            "row": "Row_2",
            "columns": null
          },
          "id": "Field_coverage",
          "key": "coverageType",
          "readonly": true
        },
        {
          "label": "Urgency Level",
          "type": "textfield",
          "layout": {
            "row": "Row_3",
            "columns": null
          },
          "id": "Field_urgency",
          "key": "urgencyLevel",
          "readonly": true
        },
        {
          "label": "Escalation Reason",
          "type": "textfield",
          "layout": {
            "row": "Row_3",
            "columns": null
          },
          "id": "Field_reason",
          "key": "escalationReason",
          "readonly": true
        },
        {
          "label": "AI Agent Case Summary",
          "type": "textarea",
          "layout": {
            "row": "Row_4",
            "columns": null
          },
          "id": "Field_caseSummary",
          "key": "caseSummary",
          "readonly": true
        }
      ],
      "showOutline": true,
      "type": "group",
      "layout": {
        "row": "Row_group1",
        "columns": null
      },
      "id": "Group_case"
    },
    {
      "label": "Clinical Decision",
      "components": [
        {
          "label": "Decision",
          "type": "select",
          "layout": {
            "row": "Row_5",
            "columns": null
          },
          "id": "Field_decision",
          "key": "overrideDecision",
          "values": [
            {
              "label": "✅ Approve — Clinical criteria met",
              "value": "approve"
            },
            {
              "label": "❌ Reject — Clinical criteria not met",
              "value": "reject"
            }
          ],
          "validate": {
            "required": true
          }
        },
        {
          "label": "Reviewer Notes",
          "type": "textarea",
          "layout": {
            "row": "Row_6",
            "columns": null
          },
          "id": "Field_notes",
          "key": "reviewerNotes",
          "validate": {
            "required": true
          }
        }
      ],
      "showOutline": true,
      "type": "group",
      "layout": {
        "row": "Row_group2",
        "columns": null
      },
      "id": "Group_decision"
    }
  ],
  "type": "default"
}